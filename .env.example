# Required secrets — set in Cloudflare Dashboard:
# Workers & Pages -> your-worker-name -> Settings -> Variables and Secrets

# Resend API key for sending contact form notification emails
# Sign up free at https://resend.com (3,000 emails/month)
# Verify your sending domain, then generate an API key
RESEND_API_KEY=re_your_api_key_here

# Email address to receive contact form submissions
RECIPIENT_EMAIL=your@email.com

# Required for build-time R2 image listing (when images not in git)
# Set in Cloudflare Worker Build -> Variables and Secrets
# Your Account ID is visible in the Cloudflare dashboard URL:
# dash.cloudflare.com/{ACCOUNT_ID}/...
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# API token with Workers R2 Storage:Read permission
# Create at dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_token_here

# R2 bucket name (set in wrangler.jsonc under r2_buckets)
# No secret needed — access is via the Worker binding (env.IMAGES)
R2_BUCKET_NAME=your-r2-bucket-name
