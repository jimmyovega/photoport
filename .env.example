# Required secrets — set these in the Cloudflare dashboard:
# Workers & Pages -> shiny-voice-19bd -> Settings -> Variables & Secrets

# Resend API key for sending contact form notification emails
# Sign up free at https://resend.com (3,000 emails/month)
# Verify azurelens.work as a sending domain, then generate an API key
RESEND_API_KEY=re_your_api_key_here

# Email address to receive contact form submissions
# Already set in wrangler.jsonc vars, but can be overridden here as a secret
RECIPIENT_EMAIL=contact@vrc6.com

# R2 bucket — set in wrangler.jsonc under r2_buckets
# No secret needed — access is via the Worker binding (env.IMAGES)
# Bucket name: azurelens-images
# Account ID: 3bdbf0f5de825de66936d7c2417e1fb2
