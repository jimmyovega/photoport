# Required environment variables
# Set these in Cloudflare Pages: Settings -> Environment variables

# Resend API key for sending contact form emails
# Sign up free at https://resend.com — 3,000 emails/month free tier
# After signup: add azurelens.work as a verified domain, then generate an API key
RESEND_API_KEY=re_your_api_key_here

# Email address to receive contact form submissions
RECIPIENT_EMAIL=contact@vrc6.com
