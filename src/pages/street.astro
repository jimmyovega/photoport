---
import Layout from '../layouts/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';

// Get all image files from the street folder
const imagesDir = join(process.cwd(), 'public', 'images', 'street');
const files = await readdir(imagesDir);

// Filter for image files and create paths
const images = files
  .filter(file => /\.(jpg|jpeg|png|webp|gif)$/i.test(file))
  .sort() // Optional: sort alphabetically
  .map(file => `/images/street/${file}`);
---

<Layout 
  title="Street Photography | Azure Lens Photography"
  description="Candid street photography by Azure Lens — authentic moments, urban life, and documentary-style images captured since 2015."
>
  <div class="container mx-auto py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
        Street Photography
      </h1>
      <p class="text-lg text-light-gray max-w-2xl mx-auto">
        Candid moments and urban landscapes captured in the streets
      </p>
    </div>
    
    <PhotoGrid images={images} altPrefix="Street photography" />
  </div>
</Layout>