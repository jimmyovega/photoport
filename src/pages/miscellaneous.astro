---
import Layout from '../layouts/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { getImages } from '../lib/getImages.mjs';

const images = await getImages('misc');
---

<Layout 
  title="Photography Portfolio | Azure Lens Photography"
  description="Creative and experimental photography work by Azure Lens — a diverse collection of subjects, styles, and visual stories."
>
  <div class="container mx-auto py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
        Miscellaneous
      </h1>
      <p class="text-lg text-light-gray max-w-2xl mx-auto">
        Experimental and creative work that doesn't fit in a box
      </p>
    </div>
    
    <PhotoGrid images={images} altPrefix="Creative photography by Azure Tincture — Azure Lens Photography, NYC" />
  </div>
</Layout>