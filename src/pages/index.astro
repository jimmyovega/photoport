---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Azure Lens Photography | New York Photographer" description="Azure Lens Photography — professional studio, fashion, commercial and street photography. Based in New York. Available for bookings since 2015.">
  <div class="relative h-[calc(100vh-8rem)] flex items-center justify-center">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero-background.webp" 
        alt="Hero background"
        class="w-full h-full object-cover opacity-40"
        width="1920"
        height="1080"
        loading="eager"
        fetchpriority="high"
        decoding="sync"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-industrial-dark/50 to-industrial-dark"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 text-center px-4">
      <h1 class="text-5xl md:text-7xl font-bold text-light-gray mb-6">
        Azure Lens Photography
      </h1>
      <p class="text-xl md:text-2xl text-accent-blue mb-8 max-w-2xl mx-auto">
        Moments. Captured. Since 2015.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a 
          href="/studio" 
          class="px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors"
        >
          View Studio Work
        </a>
        <a 
          href="/location" 
          class="px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors"
        >
          View On Location Work
        </a>
        <a 
          href="/street" 
          class="px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors"
        >
          View Street Work
        </a>
                <a 
          href="/miscellaneous" 
          class="px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors"
        >
          View Miscellaneous Work
        </a>
        <a 
          href="/contact" 
          class="px-8 py-3 border-2 border-cool-blue hover:border-accent-blue text-light-gray rounded transition-colors"
        >
          Get In Touch
        </a>
      </div>
    </div>
  </div>
</Layout>