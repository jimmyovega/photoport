---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact - Photography Portfolio"
  description="Get in touch for photography inquiries, bookings, and collaborations."
>
  <div class="container mx-auto py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
          Get In Touch
        </h1>
        <p class="text-lg text-light-gray">
          Interested in working together? Fill out the form below and I'll get back to you soon.
        </p>
      </div>
      
      <form class="bg-industrial-blue p-8 rounded-lg border border-cool-blue">
        <div class="mb-6">
          <label for="name" class="block text-light-gray mb-2 font-medium">
            Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="email" class="block text-light-gray mb-2 font-medium">
            Email *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="subject" class="block text-light-gray mb-2 font-medium">
            Subject *
          </label>
          <input 
            type="text" 
            id="subject" 
            name="subject" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="message" class="block text-light-gray mb-2 font-medium">
            Message *
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows="6"
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue resize-vertical"
          ></textarea>
        </div>
        
        <button 
          type="submit"
          class="w-full px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors font-medium"
        >
          Send Message
        </button>
      </form>
      
      <p class="text-center text-sm text-light-gray mt-6">
        Note: You'll need to integrate a form handler like Formspree, Web3Forms, or Cloudflare Pages Functions to process form submissions.
      </p>
    </div>
  </div>
</Layout>