---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact - Photography Portfolio"
  description="Get in touch for photography inquiries, bookings, and collaborations."
>
  <div class="container mx-auto py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
          Get In Touch
        </h1>
        <p class="text-lg text-light-gray">
          Interested in working together? Fill out the form below and I'll get back to you soon.
        </p>
      </div>
      
      <!-- Success message (hidden by default) -->
      <div id="success-message" class="hidden bg-cool-blue border border-accent-blue p-6 rounded-lg mb-6 text-center">
        <p class="text-light-gray text-lg">✓ Thank you! Your message has been sent successfully.</p>
      </div>
      
      <!-- Error message (hidden by default) -->
      <div id="error-message" class="hidden bg-red-900 border border-red-600 p-6 rounded-lg mb-6 text-center">
        <p class="text-light-gray text-lg">✗ Something went wrong. Please try again.</p>
      </div>
      
      <form id="contact-form" class="bg-industrial-blue p-8 rounded-lg border border-cool-blue">
        <!-- Replace with your Web3Forms access key from https://web3forms.com -->
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
        
        <!-- Honeypot for spam protection -->
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
        
        <div class="mb-6">
          <label for="name" class="block text-light-gray mb-2 font-medium">
            Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="email" class="block text-light-gray mb-2 font-medium">
            Email *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="subject" class="block text-light-gray mb-2 font-medium">
            Subject *
          </label>
          <input 
            type="text" 
            id="subject" 
            name="subject" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="message" class="block text-light-gray mb-2 font-medium">
            Message *
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows="6"
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue resize-vertical"
          ></textarea>
        </div>
        
        <button 
          type="submit"
          class="w-full px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors font-medium"
        >
          Send Message
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');
  const errorMessage = document.getElementById('error-message');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    
    // Remove access_key and botcheck fields for Cloudflare function
    delete object.access_key;
    delete object.botcheck;
    
    const json = JSON.stringify(object);
    
    // Disable button during submission
    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = button.textContent;
    button.disabled = true;
    button.textContent = 'Sending...';
    
    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: json
      });
      
      const result = await response.json();
      
      if (result.success) {
        successMessage?.classList.remove('hidden');
        errorMessage?.classList.add('hidden');
        form.reset();
        
        // Hide success message after 5 seconds
        setTimeout(() => {
          successMessage?.classList.add('hidden');
        }, 5000);
      } else {
        throw new Error(result.message || 'Form submission failed');
      }
    } catch (error) {
      console.error('Error:', error);
      errorMessage?.classList.remove('hidden');
      successMessage?.classList.add('hidden');
    } finally {
      button.disabled = false;
      button.textContent = originalText;
    }
  });
</script>