---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact - Azure Lens Photography"
  description="Get in touch for photography inquiries, bookings, and collaborations."
>
  <div class="container mx-auto py-12 px-4">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
          Get In Touch
        </h1>
        <p class="text-lg text-light-gray">
          Interested in working together? Fill out the form below and I'll get back to you soon.
        </p>
      </div>
      
      <form 
        id="contact-form"
        class="bg-industrial-blue p-8 rounded-lg border border-cool-blue"
      >
        <div class="mb-6">
          <label for="name" class="block text-light-gray mb-2 font-medium">
            Name *
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="email" class="block text-light-gray mb-2 font-medium">
            Email *
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="subject" class="block text-light-gray mb-2 font-medium">
            Subject *
          </label>
          <input 
            type="text" 
            id="subject" 
            name="subject" 
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue"
          />
        </div>
        
        <div class="mb-6">
          <label for="message" class="block text-light-gray mb-2 font-medium">
            Message *
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows="6"
            required
            class="w-full px-4 py-2 bg-industrial-dark border border-cool-blue rounded text-light-gray focus:outline-none focus:border-accent-blue resize-vertical"
          ></textarea>
        </div>
        
        <button 
          id="submit-btn"
          type="submit"
          class="w-full px-8 py-3 bg-cool-blue hover:bg-accent-blue text-light-gray rounded transition-colors font-medium disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>

        <div id="form-success" class="hidden mt-6 p-4 bg-green-900/40 border border-green-500 rounded text-green-300 text-center">
          Your message has been sent. I'll be in touch soon!
        </div>

        <div id="form-error" class="hidden mt-6 p-4 bg-red-900/40 border border-red-500 rounded text-red-300 text-center">
          Something went wrong. Please try again or email me directly.
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset state
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';

    const data = {
      name: (document.getElementById('name') as HTMLInputElement).value,
      email: (document.getElementById('email') as HTMLInputElement).value,
      subject: (document.getElementById('subject') as HTMLInputElement).value,
      message: (document.getElementById('message') as HTMLTextAreaElement).value,
    };

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.textContent = result.message || 'Something went wrong. Please try again.';
        errorMsg.classList.remove('hidden');
      }
    } catch (err) {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
