---
import Layout from '../layouts/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';
import { existsSync } from 'node:fs';

// Get all image files from the location folder
const imagesDir = join(process.cwd(), 'public', 'images', 'location');

let images = [];

// Check if directory exists before trying to read it
if (existsSync(imagesDir)) {
  const files = await readdir(imagesDir);
  
  // Filter for image files and create paths
  images = files
    .filter(file => /\.(jpg|jpeg|png|webp|gif)$/i.test(file))
    .sort() // Optional: sort alphabetically
    .map(file => `/images/location/${file}`);
}
---

<Layout 
  title="On Location Photography - Portfolio"
  description="On location photography capturing authentic moments in natural and unique settings."
>
  <div class="container mx-auto py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
        On Location
      </h1>
      <p class="text-lg text-light-gray max-w-2xl mx-auto">
        Authentic photography captured in natural environments and on-site locations
      </p>
    </div>
    
    <PhotoGrid images={images} altPrefix="On location photography" />
  </div>
</Layout>