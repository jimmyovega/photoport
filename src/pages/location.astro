---
import Layout from '../layouts/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { getImages } from '../lib/getImages.mjs';

const images = await getImages('location');
---

<Layout 
  title="On Location Photography | Azure Lens Photography"
  description="On-location photography by Azure Lens — fashion, commercial, and editorial shoots in natural and architectural environments."
>
  <div class="container mx-auto py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
        On Location Photography
      </h1>
      <p class="text-lg text-light-gray max-w-2xl mx-auto">
        Authentic photography captured in natural environments and on-site locations
      </p>
    </div>
    
    <PhotoGrid images={images} altPrefix="On-location photography by Azure Tincture — Azure Lens Photography, NYC" />
  </div>
</Layout>