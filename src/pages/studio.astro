---
import Layout from '../layouts/Layout.astro';
import PhotoGrid from '../components/PhotoGrid.astro';
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';

// Get all image files from the studio folder
const imagesDir = join(process.cwd(), 'public', 'images', 'studio');
let files = [];
try {
  files = await readdir(imagesDir);
} catch {
  // Directory may not exist locally if images are stored in R2
  files = [];
}

// Filter for image files and create paths
const images = files
  .filter(file => /\.(jpg|jpeg|png|webp|gif)$/i.test(file))
  .sort() // Optional: sort alphabetically
  .map(file => `/images/studio/${file}`);
---

<Layout 
  title="Studio Photography | Azure Lens Photography"
  description="Professional studio photography by Azure Lens — portraits, commercial shoots, and fashion work in a controlled studio environment."
>
  <div class="container mx-auto py-12">
    <div class="text-center mb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-blue mb-4">
        Studio Photography
      </h1>
      <p class="text-lg text-light-gray max-w-2xl mx-auto">
        Controlled lighting and carefully composed shots from the studio
      </p>
    </div>
    
    <PhotoGrid images={images} altPrefix="Studio photography by Azure Tincture — Azure Lens Photography, NYC" />
  </div>
</Layout>