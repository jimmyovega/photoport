---
interface Props {
  images: string[];
  altPrefix: string;
  imageData?: Array<{ src: string; width: number; height: number }>;
}

const { images, altPrefix, imageData } = Astro.props;
---

<!-- Loading skeleton -->
<div id="loading-skeleton" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0 p-4">
  {images.map(() => (
    <div class="bg-industrial-blue animate-pulse" style="height: 300px;"></div>
  ))}
</div>

<div class="masonry-container opacity-0 transition-opacity duration-500" id="masonry-container">
  <div class="masonry-grid">
    {images.map((image, index) => {
      const data = imageData?.[index];
      return (
        <div class="masonry-item group cursor-pointer relative" data-index={index}>
          <img 
            src={image}
            alt={`${altPrefix} ${index + 1}`}
            width={data?.width}
            height={data?.height}
            class="w-full h-auto transition-transform duration-300 group-hover:scale-105 lightbox-trigger"
            loading={index < 8 ? "eager" : "lazy"}
            draggable="false"
            data-index={index}
          />
          <div class="absolute inset-0 pointer-events-auto lightbox-trigger" data-index={index}></div>
        </div>
      );
    })}
  </div>
</div>

<style>
  .masonry-container {
    padding: 1rem;
  }
  
  .masonry-grid {
    column-count: 4;
    column-gap: 0.35rem;
    row-gap: 0;
  }
  
  @media (max-width: 1024px) {
    .masonry-grid {
      column-count: 3;
    }
  }
  
  @media (max-width: 768px) {
    .masonry-grid {
      column-count: 2;
    }
  }
  
  @media (max-width: 480px) {
    .masonry-grid {
      column-count: 1;
    }
  }
  
  .masonry-item {
    break-inside: avoid;
    page-break-inside: avoid;
    background: #2d3e50;
    position: relative;
    overflow: hidden;
    display: inline-block;
    width: 100%;
  }
  
  .masonry-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>

<!-- Lightbox Modal -->
<div id="lightbox" class="fixed inset-0 bg-black bg-opacity-95 hidden z-50 flex items-center justify-center">
  <button 
    id="lightbox-close" 
    class="absolute top-4 right-4 text-white text-4xl font-bold hover:text-accent-blue transition-colors z-10"
    aria-label="Close lightbox"
  >
    ×
  </button>
  
  <button 
    id="lightbox-prev" 
    class="absolute left-4 text-white text-4xl font-bold hover:text-accent-blue transition-colors z-10"
    aria-label="Previous image"
  >
    ‹
  </button>
  
  <button 
    id="lightbox-next" 
    class="absolute right-4 text-white text-4xl font-bold hover:text-accent-blue transition-colors z-10"
    aria-label="Next image"
  >
    ›
  </button>
  
  <div class="relative max-w-7xl max-h-[90vh] mx-4">
    <img 
      id="lightbox-image" 
      src="" 
      alt="" 
      class="max-w-full max-h-[90vh] object-contain"
      draggable="false"
    />
    <div id="lightbox-counter" class="absolute bottom-4 left-1/2 transform -translate-x-1/2 text-white text-lg bg-black bg-opacity-50 px-4 py-2 rounded">
      <span id="current-index">1</span> / <span id="total-images">{images.length}</span>
    </div>
  </div>
</div>

<script define:vars={{ images, altPrefix }}>
  let currentIndex = 0;
  const lightbox = document.getElementById('lightbox');
  const lightboxImage = document.getElementById('lightbox-image');
  const currentIndexSpan = document.getElementById('current-index');
  const skeleton = document.getElementById('loading-skeleton');
  const container = document.getElementById('masonry-container');
  
  // Hide skeleton and show masonry once images start loading
  function showMasonry() {
    skeleton.style.display = 'none';
    container.style.opacity = '1';
  }

  // Wait for first batch of images to fully decode before revealing grid
  // This prevents the jarring resize/reflow the user sees
  const gridImages = Array.from(document.querySelectorAll('.masonry-item img'));
  const totalImages = gridImages.length;
  const batchSize = Math.min(8, Math.ceil(totalImages * 0.3));
  const firstBatch = gridImages.slice(0, batchSize);

  // Use decode() promise so images are truly paint-ready (not just loaded)
  const decodePromises = firstBatch.map(img => {
    if (img.complete && img.naturalWidth > 0) {
      return img.decode().catch(() => Promise.resolve());
    }
    return new Promise(resolve => {
      img.addEventListener('load', () => img.decode().catch(() => {}).finally(resolve), { once: true });
      img.addEventListener('error', resolve, { once: true });
    });
  });

  // Show grid once first batch is decoded, or after 1500ms max
  const timeout = new Promise(resolve => setTimeout(resolve, 1500));
  Promise.race([Promise.all(decodePromises), timeout]).then(showMasonry);
  
  function openLightbox(index) {
    currentIndex = index;
    updateLightboxImage();
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  
  function closeLightbox() {
    lightbox.classList.add('hidden');
    document.body.style.overflow = 'auto';
  }
  
  function updateLightboxImage() {
    lightboxImage.src = images[currentIndex];
    lightboxImage.alt = `${altPrefix} ${currentIndex + 1}`;
    currentIndexSpan.textContent = currentIndex + 1;
  }
  
  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    updateLightboxImage();
  }
  
  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightboxImage();
  }
  
  // Add click listeners to all trigger elements
  document.querySelectorAll('.lightbox-trigger').forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const index = parseInt(e.target.dataset.index);
      openLightbox(index);
    });
  });
  
  // Close button
  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  
  // Navigation buttons
  document.getElementById('lightbox-prev').addEventListener('click', showPrev);
  document.getElementById('lightbox-next').addEventListener('click', showNext);
  
  // Click outside image to close
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') showNext();
      if (e.key === 'ArrowLeft') showPrev();
    }
  });
</script>